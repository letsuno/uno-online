{
  "name": "uno-online",
  "version": "0.6.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/letsuno/uno-online.git"
  },
  "packageManager": "pnpm@10.11.0",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "mediasoup"
    ]
  },
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "version:sync": "node -e \"const v=require('./package.json').version;require('child_process').execSync('pnpm -r exec npm pkg set version='+v,{stdio:'inherit'})\""
  }
}
