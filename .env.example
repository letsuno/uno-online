# ============================================
# UNO Online - 配置文件
# 复制为 .env 后按需修改
# ============================================

# --- GitHub OAuth（DEV_MODE=true 时可不填）---
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- 安全 ---
JWT_SECRET=please-change-this-to-a-random-string-at-least-32-chars

# --- 开发模式（true 时跳过 GitHub 登录，直接输入用户名）---
DEV_MODE=true
VITE_DEV_MODE=true

# --- 域名（必填，Caddy 自动申请 SSL）---
DOMAIN=example.com
# Caddy 站点地址（有域名时设为域名，本地开发设为 :80）
CADDY_SITE_ADDRESS=example.com

# --- 端口 ---
CLIENT_URL=http://localhost:5173
PORT=3001
HTTP_PORT=80
HTTPS_PORT=443
RTC_PORT=40000

# --- 数据库（默认连接 Docker 内置 PostgreSQL，外部数据库请改这里）---
DATABASE_PATH=uno.db

# --- Redis（可选，留空则使用内存存储，适合本地开发）---
# REDIS_URL=redis://redis:6379
