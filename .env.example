# ============================================
# UNO Online - 配置文件
# 复制为 .env 后按需修改
# ============================================

# --- GitHub OAuth（DEV_MODE=true 时可不填）---
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- 安全 ---
JWT_SECRET=please-change-this-to-a-random-string-at-least-32-chars

# --- 开发模式（true 时跳过 GitHub 登录，直接输入用户名）---
DEV_MODE=true

# --- 房间闲置清理（毫秒，默认 2 小时）---
ROOM_IDLE_TIMEOUT_MS=7200000

# --- 域名（必填，Caddy 自动申请 SSL）---
DOMAIN=example.com
# Caddy 站点地址（有域名时设为域名，本地开发设为 :80）
CADDY_SITE_ADDRESS=example.com

# --- 端口 ---
# 本地开发使用 http://localhost:5173；生产部署改为 https://${DOMAIN}
CLIENT_URL=http://localhost:5173
PORT=3001
HTTP_PORT=80
HTTPS_PORT=443

# --- 数据库（SQLite 文件路径）---
DATABASE_PATH=uno.db

# --- Redis（可选，留空则使用内存存储，适合本地开发）---
# REDIS_URL=redis://redis:6379

# --- 服务器信息（服务器选择器展示）---
SERVER_NAME=UNO Online
SERVER_MOTD=欢迎来到 UNO Online！

# --- GitHub OAuth 网络代理（可选）---
# GITHUB_PROXY=http://127.0.0.1:7890

# --- Mumble 语音服务（Docker 部署用）---
MUMBLE_PORT=64738
MUMBLE_GATEWAY_PORT=64737
MUMBLE_SUPERUSER_PASSWORD=admin

# --- Mumble ICE 频道管理（服务端使用，可选）---
MUMBLE_ICE_ENABLED=false
MUMBLE_ICE_HOST=mumble
MUMBLE_ICE_PORT=6502
MUMBLE_ICE_SECRET=
MUMBLE_ICE_SERVER_ID=1
MUMBLE_ICE_PARENT_CHANNEL_ID=0
MUMBLE_CHANNEL_PREFIX="UNO "
